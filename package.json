{
  "name": "jaz-clio",
  "version": "5.20.6",
  "description": "Clio: Command Line Interface Operator for Jaz AI.",
  "type": "module",
  "bin": {
    "clio": "./dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "commands"
  ],
  "scripts": {
    "build": "tsc && node --input-type=module -e \"import{readFileSync,writeFileSync}from'fs';const c=readFileSync('dist/index.js','utf8');if(!c.startsWith('#!')){writeFileSync('dist/index.js','#!/usr/bin/env node\\n'+c)}\"",
    "postbuild": "rm -rf dist/agent/prompts && cp -r src/agent/prompts dist/agent/prompts && mkdir -p dist/eval/rubrics && cp src/eval/rubrics/*.json dist/eval/rubrics/ && cp src/core/registry/dashboard-routes-manifest.json dist/core/registry/dashboard-routes-manifest.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:agent:live": "bash scripts/agent-eval-live.sh",
    "typecheck": "tsc --noEmit",
    "token-budget:check": "node scripts/token-budget-tighten.mjs",
    "token-budget:tighten": "node scripts/token-budget-tighten.mjs --apply",
    "manifest:size": "node scripts/manifest-size.mjs",
    "audit:repair-loop": "vitest run src/__tests__/eval/repair-loop-precision.test.ts",
    "prepublishOnly": "bash scripts/sync-cli-assets.sh && npm run build"
  },
  "keywords": [
    "jaz",
    "juan",
    "clio",
    "accounting",
    "bookkeeping",
    "invoicing",
    "reconciliation",
    "tax",
    "gst",
    "ifrs",
    "financial-calculator",
    "data-conversion",
    "agent-skills",
    "ai",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/teamtinvio/jaz-ai"
  },
  "author": "Jaz <api-support@jaz.ai>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "adm-zip": "^0.5.16",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "exceljs": "^4.4.0",
    "figures": "^6.1.0",
    "financial": "^0.2.4",
    "log-update": "^7.2.0",
    "node-telegram-bot-api": "^0.67.0",
    "ora": "^8.1.1",
    "papaparse": "^5.5.3",
    "undici": "^6.26.0",
    "update-notifier": "^7.3.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/adm-zip": "^0.5.6",
    "@types/node": "^22.10.1",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/papaparse": "^5.5.2",
    "@types/sanitize-html": "^2.16.1",
    "esbuild": "^0.27.3",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
